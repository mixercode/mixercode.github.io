name: Deploy Portfolio to GitHub Pages

on:
  push:
    branches: ["main"] # Cambia a "master" si es tu rama principal
  workflow_dispatch: # Permite ejecución manual desde la pestaña Actions

# Configuración de permisos necesarios para GitHub Pages
permissions:
  contents: read
  pages: write
  id-token: write

# Permite cancelar ejecuciones previas en la misma rama para optimizar recursos
concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20" # Versión LTS recomendada
          cache: 'npm'

      - name: Install Dependencies
        run: npm ci # Usa 'ci' para instalaciones consistentes en entornos de CI

      - name: Build Project
        run: npm run build
        # Asegúrate de que tu script de build genere la carpeta 'dist' o 'build'
        
      - name: Upload Build Artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: ./dist # Ajusta a './build' si usas Create React App

  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    needs: build
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
